{
  "title": "LiteLLM Router Dashboard",
  "uid": "litellm-router-v1",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "tags": ["litellm", "llm"],
  "panels": [
    {
      "id": 1,
      "title": "Requests per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(litellm_proxy_total_requests_metric_total[2m])",
          "legendFormat": "Requests/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Failed Requests per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(litellm_proxy_failed_requests_metric_total[2m])",
          "legendFormat": "Failed/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 3,
      "title": "Average Request Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(litellm_request_total_latency_metric_sum[5m]) / rate(litellm_request_total_latency_metric_count[5m])",
          "legendFormat": "Avg Latency",
          "refId": "A"
        },
        {
          "expr": "rate(litellm_llm_api_latency_metric_sum[5m]) / rate(litellm_llm_api_latency_metric_count[5m])",
          "legendFormat": "LLM API Latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 4,
      "title": "Token Usage Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(litellm_input_tokens_metric_total[2m]) * 60",
          "legendFormat": "Input Tokens/min",
          "refId": "A"
        },
        {
          "expr": "rate(litellm_output_tokens_metric_total[2m]) * 60",
          "legendFormat": "Output Tokens/min",
          "refId": "B"
        },
        {
          "expr": "rate(litellm_total_tokens_metric_total[2m]) * 60",
          "legendFormat": "Total Tokens/min",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 5,
      "title": "Requests by Deployment",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(litellm_deployment_total_requests_total[2m])",
          "legendFormat": "{{litellm_model_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 6,
      "title": "Deployment Success vs Failure",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(litellm_deployment_success_responses_total[2m])",
          "legendFormat": "Success - {{litellm_model_name}}",
          "refId": "A"
        },
        {
          "expr": "rate(litellm_deployment_failure_responses_total[2m])",
          "legendFormat": "Failure - {{litellm_model_name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 7,
      "title": "In-Flight Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "litellm_in_flight_requests",
          "legendFormat": "In-Flight",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 8,
      "title": "Spend Rate (USD/hr)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(litellm_spend_metric_total[5m]) * 3600",
          "legendFormat": "USD/hr",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 9,
      "title": "Total Requests (cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum(litellm_proxy_total_requests_metric_total)",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Total Tokens Served",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 32 },
      "targets": [
        {
          "expr": "sum(litellm_total_tokens_metric_total)",
          "legendFormat": "Total Tokens",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Total Spend (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "sum(litellm_spend_metric_total)",
          "legendFormat": "Total Spend",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Successful Fallbacks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 32 },
      "targets": [
        {
          "expr": "sum(litellm_deployment_successful_fallbacks_total)",
          "legendFormat": "Fallbacks",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Deployment State (0=healthy, 1=partial, 2=down)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "litellm_deployment_state",
          "legendFormat": "{{litellm_model_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "title": "LiteLLM Overhead Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "targets": [
        {
          "expr": "rate(litellm_overhead_latency_metric_sum[5m]) / rate(litellm_overhead_latency_metric_count[5m])",
          "legendFormat": "Overhead (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      }
    }
  ]
}
